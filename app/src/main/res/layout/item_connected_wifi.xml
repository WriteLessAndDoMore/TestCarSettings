<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="70dp"
    android:background="@drawable/shape_rectangle_corners_16_solid_blue_bg"
    android:paddingStart="15dp"
    android:paddingEnd="15dp">

    <ImageView
        android:id="@+id/iv_wifi_level_icon"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@drawable/level_list_wifi_signal_white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/iv_wifi_info_icon"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:background="@drawable/shape_oval_blue_bg"
        android:src="@drawable/ic_wifi_info_arrow"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <ImageView
        android:id="@+id/iv_wifi_lock_icon"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginEnd="20dp"
        android:src="@drawable/ic_wifi_lock_white"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/iv_wifi_info_icon"/>

    <TextView
        android:id="@+id/tv_wifi_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:layout_marginStart="20dp"
        android:ellipsize="end"
        android:singleLine="true"
        android:text="CMCC-59F34"
        android:textSize="18sp"
        android:textColor="@color/white"
        app:layout_constrainedWidth="true"
        app:layout_constraintEnd_toStartOf="@id/iv_wifi_lock_icon"
        app:layout_constraintStart_toEndOf="@+id/iv_wifi_level_icon"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_connect"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:ellipsize="end"
        android:singleLine="true"
        android:text="已连接点击分享密码"
        android:textSize="14sp"
        android:textColor="@color/white"
        app:layout_constrainedWidth="true"
        app:layout_constraintEnd_toStartOf="@+id/iv_wifi_lock_icon"
        app:layout_constraintTop_toBottomOf="@+id/tv_wifi_name"
        app:layout_constraintStart_toStartOf="@+id/tv_wifi_name"/>




</androidx.constraintlayout.widget.ConstraintLayout>