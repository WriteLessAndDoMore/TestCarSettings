<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="50dp"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="15dp"
    android:paddingEnd="15dp">

    <ImageView
        android:id="@+id/iv_wifi_level_icon"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@drawable/level_list_wifi_signal_black" />

    <TextView
        android:id="@+id/tv_wifi_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_weight="1"
        android:text="CMCC-59FQ"
        android:textSize="24sp" />

    <ImageView
        android:id="@+id/iv_wifi_lock_icon"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginEnd="20dp"
        android:src="@drawable/ic_wifi_lock_black" />

    <ImageView
        android:id="@+id/iv_wifi_info_icon"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:background="@drawable/shape_oval_bg"
        android:src="@drawable/ic_wifi_info_arrow" />


</LinearLayout>